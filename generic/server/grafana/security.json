                      "query": "from(bucket: \"konnected\")\n  |> range(start: v.timeRangeStart, stop:v.timeRangeStop)\n  |> filter(fn: (r) =>\n    r._measurement == \"Frontdoor\" and\n    r._field == \"value\"\n  )"
